{
  "name": "server",
  "version": "0.4.0-alpha",
  "description": "",
  "main": "dist/server.js",
  "bin": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/server.ts",
    "start": "tsx src/server.ts",
    "test": "vitest run",
    "import": "tsx src/cli.ts",
    "elevate": "tsx src/elevate.ts",
    "build": "tsc",
    "package": "npm run build && pkg . --targets node18-win-x64 --output release/harmony-server.exe"
  },
  "pkg": {
    "assets": [
      "node_modules/sqlite3/build/Release/*.node",
      "node_modules/mediasoup/worker/out/Release/mediasoup-worker.exe"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "file-type": "^16.5.4",
    "jsonwebtoken": "^9.0.3",
    "mediasoup": "^3.19.19",
    "multer": "^2.1.1",
    "selfsigned": "^5.5.0",
    "sqlite3": "^5.1.7",
    "stream-json": "^2.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/selfsigned": "^2.0.4",
    "@types/stream-json": "^1.7.8",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.4",
    "nodemon": "^3.1.14",
    "pkg": "^5.8.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
