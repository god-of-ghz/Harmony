{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "bin": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/server.ts",
    "start": "tsx src/server.ts",
    "test": "vitest run",
    "import": "tsx src/cli.ts",
    "elevate": "tsx src/elevate.ts",
    "build": "tsc",
    "package": "npm run build && pkg . --targets node18-win-x64 --output release/harmony-server.exe"
  },
  "pkg": {
    "assets": [
      "node_modules/sqlite3/lib/binding/**/*.node"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "sqlite3": "^5.1.7",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.14",
    "pkg": "^5.8.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
